# Copy to .env and fill in. Never commit the real .env.

# FRED — free at https://fred.stlouisfed.org/
# Used by Case 1, 5 macro features (VIX, term-spread, credit-spread).
FRED_API_KEY=your_key_here

# Groq — free tier at https://groq.com/
# Used by Case 4 LLM sentiment (model llama-3.3-70b-versatile by default).
GROQ_API_KEY=your_key_here

# Optional: local Ollama fallback for Case 4 (Apple Silicon Macs benefit
# from MPS GPU). Set to e.g. http://localhost:11434.
# OLLAMA_HOST=http://localhost:11434

# Used by CI to substitute bundled samples/ snapshots for live API calls.
# BACKTESTER_FIXTURE_MODE=1
